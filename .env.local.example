# Copy to .env.local and fill in. .env.local is gitignored.

# Shared secret proving a request to /v1/admin/* came from the trusted
# Next.js web server (which already verified the admin's own session), not
# directly from a browser. Must match the same value in web/.env.local.
# Generate with:
#   openssl rand -base64 48
ADMIN_API_TOKEN=

# GitHub personal access token used to commit and push admin-driven changes
# (the ledger now, catalog data later) directly to this repo's remote and to
# opencigardb/catalog. Needs Contents: Read and write on both repos. Never
# written to .git/config — src/git/commit.ts uses it only in a one-off
# push URL. Create at github.com/settings/personal-access-tokens.
GIT_PUSH_TOKEN=
